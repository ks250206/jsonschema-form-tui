{
  "title": "Profile",
  "type": "object",
  "$defs": {
    "address": {
      "type": "object",
      "properties": {
        "city": { "type": "string", "default": "Tokyo" },
        "zip": { "type": "string", "default": "100-0001" }
      }
    }
  },
  "properties": {
    "username": { "type": "string", "default": "ryo" },
    "age": { "type": "integer", "default": 30 },
    "address": { "$ref": "#/$defs/address" }
  }
}
